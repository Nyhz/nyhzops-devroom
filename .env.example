# ═══════════════════════════════════════════
#   NYHZ OPS — DEVROOM
#   Environment Configuration
# ═══════════════════════════════════════════

# ─── Server ────────────────────────────────
DEVROOM_PORT=7777                        # HTTP server port
DEVROOM_HOST=0.0.0.0                     # Bind address (0.0.0.0 for LAN access)

# ─── Database ──────────────────────────────
DEVROOM_DB_PATH=./devroom.db             # SQLite file path

# ─── Battlefields ──────────────────────────
DEVROOM_DEV_BASE_PATH=/dev               # Base directory for new battlefield repos

# ─── Orchestrator ──────────────────────────
DEVROOM_MAX_AGENTS=5                     # Max concurrent Claude Code processes
DEVROOM_CLAUDE_PATH=claude               # Path to Claude Code CLI binary

# ─── Auth ──────────────────────────────────
# Long-lived OAuth token from `claude setup-token` (valid ~1 year)
# Bypasses Keychain extraction — prevents auth expiry during unattended operation
CLAUDE_CODE_OAUTH_TOKEN=                 # sk-ant-oat01-...

# ─── Logging ───────────────────────────────
DEVROOM_LOG_LEVEL=info                   # debug | info | warn | error
DEVROOM_LOG_RETENTION_DAYS=30            # Days to keep mission logs before cleanup

# ─── Telegram (Overseer Escalations) ──────
# Optional — Commander notifications via Telegram bot
# See docs for setup: create bot via @BotFather, get chat ID
DEVROOM_TELEGRAM_ENABLED=false           # Set to 'true' to enable Telegram alerts
DEVROOM_TELEGRAM_BOT_TOKEN=              # Bot token from @BotFather (e.g., 7123456789:AAHxxx...)
DEVROOM_TELEGRAM_CHAT_ID=               # Your Telegram chat ID (numeric)
